# MySQL đã deploy sẵn — điền 5 biến này
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=DataManager

# Prisma đọc DATABASE_URL; nếu để trống, app tự build từ 5 biến trên (xem src/lib/db-url.ts).
# Có thể set trực tiếp để override:
# DATABASE_URL="mysql://user:pass@host:3306/DataManager"

# Bí mật ký session cookie (đổi thành chuỗi ngẫu nhiên dài)
# Tạo bằng: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# Cổng server (mặc định 3000)
# PORT=3000

# Cookie phiên mặc định có cờ Secure khi NODE_ENV=production, nghĩa là trình
# duyệt CHỈ gửi nó qua HTTPS. Nếu truy cập thẳng qua http://ip:port thì đăng
# nhập xong sẽ bị đá về trang login vì cookie không được lưu.
#   - Có HTTPS (nginx/caddy)  -> để trống, giữ mặc định an toàn.
#   - Chạy HTTP thuần         -> COOKIE_SECURE=false
# Chỉ nên đặt false trong mạng nội bộ tin cậy: cookie phiên sẽ đi qua mạng ở
# dạng không mã hoá và có thể bị nghe lén.
# COOKIE_SECURE=false

# Tài khoản admin seed lần đầu
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Quản lý
