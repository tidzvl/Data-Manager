generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

/// Chuyền may — 1 chuyền có thể nhận nhiều LSX cùng lúc.
model SewingLine {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  createdAt DateTime          @default(now())
  orders    ProductionOrder[]
}

/// Danh mục kích thước dùng chung (dropdown nhanh).
model SizeType {
  id       Int    @id @default(autoincrement())
  label    String @unique
  position Int    @default(0)
}

/// Danh mục chi tiết dùng chung, mỗi chi tiết 1 màu để dễ phân biệt.
model PartType {
  id       Int    @id @default(autoincrement())
  name     String @unique
  color    String @db.VarChar(9)
  position Int    @default(0)
}

enum OrderStatus {
  ACTIVE
  DONE
}

model ProductionOrder {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  productName String
  /// Mỗi LSX chỉ do 1 chuyền may phụ trách.
  lineId      Int?
  status      OrderStatus @default(ACTIVE)
  note        String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  line       SewingLine? @relation(fields: [lineId], references: [id], onDelete: SetNull)
  categories Category[]
  movements  Movement[]

  @@index([lineId])
  @@index([createdAt])
}

model Category {
  id       Int    @id @default(autoincrement())
  orderId  Int
  name     String
  position Int    @default(0)

  order      ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderSizes OrderSize[]
  parts      Part[]
  stages     Stage[]

  @@index([orderId])
}

/// Một dòng trên bảng quản lý: đúng một mục của một phân loại.
///
/// Hai giống mục sống chung ở đây:
///   - Mục HỆ THỐNG (`type` khác null): một trong 4 công đoạn của luồng sản
///     xuất. Chỉ chúng mới tính vào tiến độ, nhật ký, xuất file.
///   - Mục TỰ DO (`type` null, `name` bắt buộc): người dùng tự đặt tên. Chỉ có
///     đợt và số lượng; không tham gia luồng.
///
/// `type` null được nên `@@unique([categoryId, type])` vẫn chặn trùng mục hệ
/// thống — MySQL coi mỗi NULL là một giá trị khác nhau, nên mục tự do thêm bao
/// nhiêu cũng được.
///
/// `name` ở mục hệ thống là nhãn ĐÈ LÊN nhãn mặc định của `type` (rỗng = dùng
/// mặc định): đổi tên hiển thị mà không đụng gì tới luồng.
model Stage {
  id         Int           @id @default(autoincrement())
  categoryId Int
  type       MovementType?
  name       String?
  position   Int           @default(0)
  createdAt  DateTime      @default(now())

  category  Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  targets   StageTarget[]
  movements Movement[]

  @@unique([categoryId, type])
  @@index([categoryId])
}

/// SL kế hoạch của một công đoạn theo từng size.
/// Riêng "Gửi may" không dùng bảng này: target của nó là tổng định mức các chi
/// tiết (PartTarget), để dòng cha luôn bằng tổng các dòng con.
model StageTarget {
  id          Int @id @default(autoincrement())
  stageId     Int
  orderSizeId Int
  targetQty   Int @default(0)

  stage     Stage     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  orderSize OrderSize @relation(fields: [orderSizeId], references: [id], onDelete: Cascade)

  @@unique([stageId, orderSizeId])
  @@index([orderSizeId])
}

model OrderSize {
  id         Int    @id @default(autoincrement())
  categoryId Int
  sizeLabel  String
  /// SL thành phẩm kế hoạch của phân loại. Target theo từng mục nằm ở StageTarget.
  targetQty  Int    @default(0)
  position   Int    @default(0)

  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  partTargets  PartTarget[]
  stageTargets StageTarget[]
  items        MovementItem[]

  @@index([categoryId])
}

model Part {
  id         Int     @id @default(autoincrement())
  categoryId Int
  name       String
  /// Màu lấy từ PartType lúc tạo, để hiển thị nhất quán.
  color      String? @db.VarChar(9)
  position   Int     @default(0)

  category  Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  targets   PartTarget[]
  items     MovementItem[]
  movements Movement[]

  @@index([categoryId])
}

model PartTarget {
  id          Int @id @default(autoincrement())
  partId      Int
  orderSizeId Int
  targetQty   Int @default(0)

  part      Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
  orderSize OrderSize @relation(fields: [orderSizeId], references: [id], onDelete: Cascade)

  @@unique([partId, orderSizeId])
  @@index([orderSizeId])
}

enum MovementType {
  SEW_OUT // Xuất chi tiết về chuyền may
  SEW_IN // Chuyền may gửi thành phẩm lên
  EMB_OUT // Gửi đi thêu
  EMB_IN // Nhận về từ thêu
}

/// Một đợt gửi/nhận.
///
/// `type` là cách gắn phiếu vào mục từ trước tới nay: khớp `movement.type` với
/// `stage.type`, còn phân loại thì suy từ `orderSize` của từng item. Một phiếu
/// nhập từ form vì thế có thể trải qua nhiều phân loại.
///
/// `stageId`/`partId` là cách gắn TRỰC TIẾP, cho những đợt tạo từ bảng: chúng
/// thuộc đúng một mục (và một chi tiết, nếu là "Gửi may"). Bắt buộc phải có, vì
/// đợt tạo từ bảng bắt đầu bằng số liệu RỖNG — không còn item nào để suy ngược
/// ra nó thuộc phân loại nào.
///
/// Mục tự do chỉ nhận diện được bằng `stageId`; `type` của nó là null.
model Movement {
  id        Int           @id @default(autoincrement())
  orderId   Int
  type      MovementType?
  stageId   Int?
  partId    Int?
  date      DateTime      @db.Date
  note      String?       @db.Text
  createdAt DateTime      @default(now())

  order ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stage Stage?          @relation(fields: [stageId], references: [id], onDelete: SetNull)
  part  Part?           @relation(fields: [partId], references: [id], onDelete: Cascade)
  items MovementItem[]

  @@index([orderId, type])
  @@index([stageId])
  @@index([partId])
  @@index([date])
}

model MovementItem {
  id          Int @id @default(autoincrement())
  movementId  Int
  orderSizeId Int
  partId      Int?
  quantity    Int

  movement  Movement  @relation(fields: [movementId], references: [id], onDelete: Cascade)
  orderSize OrderSize @relation(fields: [orderSizeId], references: [id], onDelete: Cascade)
  part      Part?     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([movementId])
  @@index([orderSizeId])
  @@index([partId])
}
